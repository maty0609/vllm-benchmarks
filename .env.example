# vLLM Benchmark Configuration
# Copy this file to .env and fill in your values
# DO NOT commit the .env file with real values to version control

# Remote server configuration
VLLM_BASE_URL="http://localhost:8000"
VLLM_API_KEY="your-api-key-here"

# GPU Type (optional)
# vLLM doesn't expose GPU model via API, so you can specify it manually
# Examples: "NVIDIA A100 80GB", "NVIDIA H100 80GB", "NVIDIA RTX 4090"
GPU_TYPE="NVIDIA A100 80GB"

# vLLM Server Parameters (optional)
# These are the parameters used when starting the vLLM server
# Update these to match your actual server configuration
# The benchmark will display these in the summary for reference

# GPU Memory Utilization (0.0-1.0)
VLLM_GPU_MEMORY_UTILIZATION="0.95"

# Auto Tool Choice (true/false)
VLLM_ENABLE_AUTO_TOOL_CHOICE="true"

# Tool Call Parser
VLLM_TOOL_CALL_PARSER="qwen3_coder"

# Reasoning Parser
VLLM_REASONING_PARSER="qwen3"

# Language Model Only (true/false)
VLLM_LANGUAGE_MODEL_ONLY="true"

# Enable Prefix Caching (true/false)
VLLM_ENABLE_PREFIX_CACHING="true"

# Max Model Length (tokens)
VLLM_MAX_MODEL_LEN="131072"

# Enforce Eager Mode (true/false)
VLLM_ENFORCE_EAGER="true"

# Trust Remote Code (true/false)
VLLM_TRUST_REMOTE_CODE="true"
